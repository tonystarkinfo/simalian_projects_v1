# Porta do servidor (opcional; default 3001)
PORT=3001

# E-mail que recebe os contactos (obrigatório)
CONTACT_EMAIL=seu-email@gmail.com

# SMTP – exemplo Gmail (use "Palavra-passe de aplicação", não a senha normal)
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua_palavra_passe_de_aplicacao
SMTP_FROM=seu-email@gmail.com

# Para outro fornecedor (ex: SendGrid, Mailgun), altere SMTP_HOST e SMTP_PORT.
